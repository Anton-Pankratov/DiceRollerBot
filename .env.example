# Режим работы: prod (продакшн) или test (тестовый)
BOT_MODE=prod

# Токен вашего Телеграм-бота, полученный от @BotFather
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
BOT_TOKEN_TEST=9876543210:ZYXwvuTsrQPonMlKjIhGfEdCbA

# Таймаут между бросками дайсов для защиты от спама (в секундах)
THROTTLING_RATE=1.0

# Соль для хеширования Telegram User ID в базе данных для обеспечения конфиденциальности
DB_SALT=replace_with_your_random_secret_salt_string

# Настройки Telegram Mini App (Web App)
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8000
# Ссылка на Mini App (для Telegram). При тестировании локально можно оставить http://localhost:8000, 
# но для работы в Telegram клиенте нужен HTTPS (например, ngrok ссылка: https://xxxx.ngrok-free.app)
WEBAPP_URL=http://localhost:8000
